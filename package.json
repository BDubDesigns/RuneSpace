{
  "name": "runespace",
  "version": "0.1.0",
  "private": true,
  "description": "RuneSpace — browser-first, mobile-friendly, low-fi sci-fi RPG (foundation scaffold).",
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "pnpm": ">=9.0.0 <10.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "next": "15.5.20",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "drizzle-orm": "0.45.2",
    "better-auth": "1.6.23",
    "@better-auth/drizzle-adapter": "1.6.23",
    "pg": "8.13.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@playwright/test": "1.51.1",
    "autoprefixer": "10.4.20",
    "@types/node": "22.10.7",
    "@types/pg": "8.11.10",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "drizzle-kit": "0.31.10",
    "@better-auth/cli": "1.4.21",
    "eslint": "9.18.0",
    "eslint-config-next": "15.5.20",
    "prettier": "3.4.2",
    "prettier-plugin-tailwindcss": "0.6.9",
    "tailwindcss": "3.4.17",
    "postcss": "8.5.1",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
